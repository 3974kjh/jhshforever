# Supabase (방명록)
# 공개(클라이언트 노출 가능) 값
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# 서버 전용 - 절대 클라이언트에 노출 금지 (방명록 삭제/비밀번호 검증에 사용)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# 네이버 지도 (Maps JS v3, ncpKeyId)
PUBLIC_NAVER_MAP_CLIENT_ID="your-naver-map-client-id"

# 카카오 공유 (선택) - 없으면 링크 복사로 폴백
PUBLIC_KAKAO_JS_KEY=""
